@model IEnumerable<RestroManagement.DbModels.Order>
@{
    ViewData["Title"] = "Home";
}


<div class="container py-3">
   
    <!-- Dashboard Heading -->
    <div class="text-center mb-3">
        <h1 class="fw-bold text-danger">🍴 Restaurant Dashboard</h1>
        <p class="lead text-muted">Manage your restaurant operations easily</p>
    </div>



    <!-- Summary Cards -->
    
    <!-- Management Section -->
    <div class="row g-4 mt-2">
    <div class="row g-4">

        <div class="col-md-4">
            <div class="card shadow-lg border-0 text-center p-4">
                <h4>📋 Manage Orders</h4>
                <p>View and update customer orders.</p>
                <a href="/Restaurant/Orders" class="btn btn-primary">
                    View Orders
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-lg border-0 text-center p-4">
                <h4>🍔 Manage Menu</h4>
                <p>Add, edit or remove food items.</p>
                <a href="/Restaurant/FoodItems" class="btn btn-success">
                    Manage Menu
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-lg border-0 text-center p-4">
                <h4>👥 Customers</h4>
                <p>Track customer details.</p>
                <a href="/Restaurant/Home/Customers" class="btn btn-warning">
                    View Customers
                </a>
            </div>
        </div>

    </div>
    <div class="row g-4 mb-5">

        <div class="col-md-3">
            <div class="card shadow border-0 text-center p-4">
                <h3 class="fw-bold mb-0">@ViewBag.OrderCount</h3>
                <p>Total Orders</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 text-center p-4">
                <h3 class="fw-bold mb-0">₹@ViewBag.TotalRevenue</h3>
                <p>Revenue</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 text-center p-4">
                <h3 class="fw-bold mb-0">@ViewBag.FoodItemCount</h3>
                <p>Menu Items</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 text-center p-4">
                <h3 class="text-danger">18</h3>
                <p>Pending Orders</p>
            </div>
        </div>

    </div>

    <!-- Recent Orders Table -->
   
</div>
        <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
        <script src="~/js/orders.js"></script>