@model IEnumerable<RestroManagement.DbModels.User.AppUser>

<div class="container mt-4">
	<h3 class="mb-3">Customers</h3>

	<div class="table-responsive">
		<table class="table table-striped table-bordered">
			<thead class="table-dark">
				<tr>
					<th>Id</th>
					<th>UserName</th>
					<th>First Name</th>
					<th>Last Name</th>
					<th>Email</th>
					<th>Phone</th>
				</tr>
			</thead>
			<tbody>
				@if (Model != null && Model.Any())
				{
					foreach (var u in Model)
					{
						<tr>
							<td>@u.Id</td>
							<td>@u.UserName</td>
							<td>@u.FName</td>
							<td>@u.LName</td>
							<td>@u.Email</td>
							<td>@u.PhoneNumber</td>
						</tr>
					}
				}
				else
				{
					<tr>
						<td colspan="6" class="text-center">No customers found.</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
</div>
