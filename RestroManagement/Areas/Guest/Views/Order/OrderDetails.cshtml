@model RestroManagement.DbModels.Order

<style>
    .track-order-container {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        padding: 30px;
        margin-bottom: 30px;
        border: 1px solid #eef2f5;
    }
    .stepper-wrapper {
        display: flex;
        justify-content: space-between;
        position: relative;
        margin-bottom: 20px;
    }
    .stepper-wrapper::before {
        content: '';
        position: absolute;
        top: 25px;
        left: 10%;
        width: 80%;
        height: 4px;
        background-color: #e9ecef;
        z-index: 1;
    }
    .stepper-progress {
        position: absolute;
        top: 25px;
        left: 10%;
        height: 4px;
        background: linear-gradient(90deg, #10B981, #059669);
        z-index: 1;
        transition: width 0.4s ease;
    }
    .stepper-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        z-index: 2;
        flex: 1;
    }
    .step-counter {
        position: relative;
        width: 54px;
        height: 54px;
        border-radius: 50%;
        background: #f8f9fa;
        border: 3px solid #e9ecef;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 20px;
        color: #6c757d;
        transition: all 0.4s ease;
    }
    .step-name {
        margin-top: 10px;
        font-size: 14px;
        font-weight: 600;
        color: #6c757d;
        text-align: center;
        transition: all 0.4s ease;
    }
    
    /* Completed state */
    .stepper-item.completed .step-counter {
        background-color: #10B981;
        border-color: #10B981;
        color: #ffffff;
        box-shadow: 0 4px 10px rgba(16, 185, 129, 0.2);
    }
    .stepper-item.completed .step-name {
        color: #10B981;
    }

    /* Active state */
    .stepper-item.active .step-counter {
        background-color: #0d6efd;
        border-color: #0d6efd;
        color: #ffffff;
        box-shadow: 0 4px 15px rgba(13, 110, 253, 0.4);
        animation: pulse-step 2s infinite;
    }
    .stepper-item.active .step-name {
        color: #0d6efd;
        font-weight: 700;
    }

    @@keyframes pulse-step {
        0% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.5); }
        70% { box-shadow: 0 0 0 10px rgba(13, 110, 253, 0); }
        100% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0); }
    }
</style>

<div class="container mt-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
        <h2>Order Details</h2>
        <a asp-action="MyOrders" class="btn btn-secondary">
            ← Back to My Orders
        </a>
    </div>

    <!-- Live Order Tracking -->
    <div class="track-order-container">
        <h4 class="fw-bold mb-4 text-center">🍽️ Live Order Tracking</h4>
        
        <div id="cancelled-alert" class="alert alert-danger text-center py-3" style="display: none; border-radius: 12px;">
            <i class="bi bi-x-circle-fill fs-3 d-block mb-2"></i>
            <span class="fw-bold fs-5">This order has been cancelled.</span>
        </div>

        <div id="standard-stepper" class="position-relative">
            <div class="stepper-wrapper">
                <div id="stepper-progress" class="stepper-progress" style="width: 0%;"></div>
                
                <div class="stepper-item">
                    <div class="step-counter"><i class="bi bi-clipboard-check"></i></div>
                    <div class="step-name">Order Placed</div>
                </div>
                <div class="stepper-item">
                    <div class="step-counter"><i class="bi bi-check-circle"></i></div>
                    <div class="step-name">Confirmed</div>
                </div>
                <div class="stepper-item">
                    <div class="step-counter"><i class="bi bi-egg-fried"></i></div>
                    <div class="step-name">Preparing</div>
                </div>
                <div class="stepper-item">
                    <div class="step-counter"><i class="bi bi-bell"></i></div>
                    <div class="step-name">Ready for Pickup</div>
                </div>
                <div class="stepper-item">
                    <div class="step-counter"><i class="bi bi-bag-heart"></i></div>
                    <div class="step-name">Delivered</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <h5>Customer Information</h5>
                    <p>
                        <strong>Name:</strong> @Model.CustomerName
                    </p>
                    <p>
                        <strong>Mobile:</strong> @Model.MobileNumber
                    </p>
                    <p>
                        <strong>Order Date:</strong>
                        @Model.OrderDate.ToString("dd MMM yyyy hh:mm tt")
                    </p>
                </div>
                <div class="col-md-6 text-md-end">
                    <h5>Order #@Model.Id</h5>
                    <h4 class="text-success">
                        ₹@Model.OrderTotal
                    </h4>
                </div>
            </div>
        </div>
    </div>
    <div class="card shadow-sm">

        <div class="card-header bg-primary text-white">
            Ordered Items
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Food Item</th>
                            <th>Portion</th>
                            <th>Quantity</th>
                            <th>Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.FoodItem?.Name</td>
                                <td>@item.Portion?.Name</td>
                                <td>@item.Quantity</td>
                                <td>₹@item.Price</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="card mt-4">

        <div class="card-header">
            Bill Summary
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table mb-0">
                    <tr>
                        <td>Subtotal</td>
                        <td class="text-end">₹@Model.TotalPrice</td>
                    </tr>
                    <tr>
                        <td>SGST</td>
                        <td class="text-end">₹@Model.SGST</td>
                    </tr>
                    <tr>
                        <td>CGST</td>
                        <td class="text-end">₹@Model.CGST</td>
                    </tr>
                    <tr>
                        <td>Packaging Charges</td>
                        <td class="text-end">₹@Model.PackagingCharges</td>
                    </tr>
                    <tr class="table-success fw-bold">
                        <td>Grand Total</td>
                        <td class="text-end">
                            ₹@Model.OrderTotal
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var orderId = @Model.Id;
            function pollStatus() {
                $.ajax({
                    url: '@Url.Action("GetOrderStatus", "Order", new { area = "Guest" })',
                    type: 'GET',
                    data: { id: orderId },
                    success: function(data) {
                        updateStepper(data.statusValue);
                        if (data.statusValue === 4 || data.statusValue === 5) {
                            clearInterval(pollInterval);
                        }
                    },
                    error: function(err) {
                        console.error("Error polling order status:", err);
                    }
                });
            }

            function updateStepper(statusVal) {
                var stepsCount = 5;
                if (statusVal === 5) { // Cancelled
                    $('#standard-stepper').hide();
                    $('#cancelled-alert').fadeIn();
                    return;
                }
                $('#cancelled-alert').hide();
                $('#standard-stepper').show();

                var progressWidth = (statusVal / (stepsCount - 1)) * 80;
                $('#stepper-progress').css('width', progressWidth + '%');

                $('.stepper-item').each(function(index) {
                    $(this).removeClass('completed active');
                    if (index < statusVal) {
                        $(this).addClass('completed');
                    } else if (index === statusVal) {
                        $(this).addClass('active');
                    }
                });
            }

            pollStatus();
            var pollInterval = setInterval(pollStatus, 5000);
        });
    </script>
}