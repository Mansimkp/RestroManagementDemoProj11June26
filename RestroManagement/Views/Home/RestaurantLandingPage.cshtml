@model List<RestroManagement.DbModels.FoodItem>
@{
    Layout = null;
    var merchant = ViewBag.Merchant as RestroManagement.DbModels.Merchant;
    var store = ViewBag.Store as RestroManagement.DbModels.Store;
    var restaurantName = store?.StoreName ?? merchant?.CompanyName ?? "Gourmet Kitchen";
    var restaurantDescription = store?.StoreDescription ?? merchant?.Description ?? "Experience culinary excellence and authentic flavors crafted by our master chefs.";
    var address = store?.StoreAddress ?? "123 Gourmet Boulevard, Food District";
    
    // Extract unique categories from the items
    var categories = Model
        .SelectMany(f => f.Categories ?? new List<RestroManagement.DbModels.FoodItemCategory>())
        .Select(fc => fc.Category)
        .Where(c => c != null)
        .GroupBy(c => c!.Id)
        .Select(g => g.First())
        .OrderBy(c => c!.DisplayOrder)
        .ToList();
}

<!DOCTYPE html> 
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@restaurantName - Welcome & Order Online</title>
    
    <!-- Google Fonts: Playfair Display for Headings, Inter for Body -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,600&display=swap" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <link href="~/css/restaurentlandingpage.css" rel="stylesheet" />

</head>
<body x-data="restaurantApp" :class="{ 'body-scroll-lock': cartOpen || mobileMenuOpen }">

    <!-- Header Navigation -->
    <header id="site-header">
        <div class="container header-inner">
            <a href="#" class="brand-logo">
                <i class="bi bi-egg-fried"></i>
                <span>@restaurantName</span>
            </a>
            
            <ul class="nav-menu">
                <li><a href="#">Home</a></li>
                <li><a href="#services">Services</a></li>
                <li><a href="#menu">Our Menu</a></li>
                <li><a href="#footer">Contact</a></li>
            </ul>
            
            <div class="nav-actions">
                <button class="cart-trigger" x-on:click="cartOpen = true">
                    <i class="bi bi-cart3"></i>
                    <span>My Cart</span>
                    <span class="cart-badge" x-text="totalQty"></span>
                </button>
                
                <!-- Hamburger Menu Button for Mobile -->
                <button class="mobile-menu-btn" x-on:click="mobileMenuOpen = !mobileMenuOpen" aria-label="Toggle Menu">
                    <i class="bi" :class="mobileMenuOpen ? 'bi-x-lg' : 'bi-list'"></i>
                </button>
            </div>
        </div>
    </header>

    <!-- Mobile Navigation Menu Dropdown -->
    <div class="mobile-nav-menu" 
         x-show="mobileMenuOpen" 
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 -translate-y-4"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100 translate-y-0"
         x-transition:leave-end="opacity-0 -translate-y-4"
         x-on:click.away="mobileMenuOpen = false"
         style="display: none;">
        <ul class="mobile-nav-list">
            <li><a href="#" x-on:click="mobileMenuOpen = false"><i class="bi bi-house-door"></i> Home</a></li>
            <li><a href="#services" x-on:click="mobileMenuOpen = false"><i class="bi bi-cup-hot"></i> Services</a></li>
            <li><a href="#menu" x-on:click="mobileMenuOpen = false"><i class="bi bi-book"></i> Our Menu</a></li>
            <li><a href="#footer" x-on:click="mobileMenuOpen = false"><i class="bi bi-telephone"></i> Contact</a></li>
        </ul>
    </div>

    <!-- Hero Banner Section -->
    <section class="hero-banner">
        <div class="container">
            <div class="hero-content">
                <div class="hero-badge">
                    <i class="bi bi-award-fill"></i>
                    <span>Top Rated Culinary Destination</span>
                </div>
                <h1>Fresh Ingredients. <br><span>Exceptional Taste.</span></h1>
                <p>@restaurantDescription Enjoy dine-in convenience or place a customized order online for takeaway or contactless home delivery.</p>
                <div class="hero-buttons">
                    <a href="#menu" class="btn btn-primary">Order Now &amp; Eat</a>
                    <a href="#services" class="btn btn-secondary">Explore Services</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick Info Grid -->
    <div class="container">
        <div class="info-grid">
            <div class="info-card">
                <div class="info-icon"><i class="bi bi-geo-alt"></i></div>
                <div>
                    <h4>Locate Us</h4>
                    <p>@address</p>
                </div>
            </div>
            <div class="info-card">
                <div class="info-icon"><i class="bi bi-clock"></i></div>
                <div>
                    <h4>Working Hours</h4>
                    <p>Everyday: 11:00 AM - 11:00 PM</p>
                </div>
            </div>
            <div class="info-card">
                <div class="info-icon"><i class="bi bi-telephone"></i></div>
                <div>
                    <h4>Book Table / Inquiry</h4>
                    <p>+91 98765 43210</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Restaurant Services Section -->
    <section class="services-section" id="services">
        <div class="container">
            <div class="section-header">
                <span>What We Do</span>
                <h2>Our Premium Services</h2>
                <p>We pride ourselves on offering outstanding hospitality and culinary experiences tailored to your preference.</p>
            </div>
            
            <div class="services-grid">
                <div class="service-card">
                    <i class="bi bi-cup-hot"></i>
                    <h3>Dine-in Experience</h3>
                    <p>Cozy ambient seating, beautiful lighting, and stellar personalized service for families and friends.</p>
                </div>
                <div class="service-card">
                    <i class="bi bi-bag-heart"></i>
                    <h3>Quick Takeaway</h3>
                    <p>Order online ahead of time and grab your hot, freshly packed meal on the go without waiting.</p>
                </div>
                <div class="service-card">
                    <i class="bi bi-truck"></i>
                    <h3>Contactless Delivery</h3>
                    <p>Super-fast delivery straight to your doorstep, sealed with premium, temperature-insulated packaging.</p>
                </div>
                <div class="service-card">
                    <i class="bi bi-calendar-event"></i>
                    <h3>Private Catering</h3>
                    <p>Celebrate your milestone events, weddings, or corporate meets with a curated gourmet buffet menu.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Rich Menu & Ordering Section -->
    <section class="menu-section" id="menu">
        <div class="container">
            <div class="section-header">
                <span>Craving Something Delicious?</span>
                <h2>Explore Our Culinary Collection</h2>
                <p>Filter by categories, search items, and select portions to place your order directly.</p>
            </div>
            
            <!-- Controls: Search & Preference Filters -->
            <div class="menu-controls">
                <div class="search-wrapper">
                    <i class="bi bi-search"></i>
                    <input type="text" class="search-input" id="menu-search" placeholder="Search for Paneer Tikka, Rabdi, Dal..." x-model="searchQuery">
                </div>
                
                <div class="diet-filters">
                    <button class="diet-btn" data-diet="all" :class="{ 'active': activeDiet === 'all' }" x-on:click="activeDiet = 'all'">
                        All Items
                    </button>
                    <button class="diet-btn" data-diet="veg" :class="{ 'active': activeDiet === 'veg' }" x-on:click="activeDiet = 'veg'">
                        <span class="badge-dot" style="background-color: var(--veg-color)"></span>
                        Vegetarian
                    </button>
                    <button class="diet-btn" data-diet="nonveg" :class="{ 'active': activeDiet === 'nonveg' }" x-on:click="activeDiet = 'nonveg'">
                        <span class="badge-dot" style="background-color: var(--nonveg-color)"></span>
                        Non-Vegetarian
                    </button>
                </div>
            </div>

            <!-- Category Pills/Tabs -->
            <div class="category-tabs">
                <button class="category-tab" :class="{ 'active': activeCategory === 'all' }" x-on:click="activeCategory = 'all'">All Categories</button>
                @foreach (var cat in categories)
                {
                    <button class="category-tab" :class="{ 'active': activeCategory === '@cat.Id' }" x-on:click="activeCategory = '@cat.Id'">@cat.Name</button>
                }
            </div>

            <!-- Menu Grid -->
            <div class="menu-grid" id="menu-items-grid">
                @foreach (var item in Model)
                {
                    var isVeg = item.DietaryPreference == RestroManagement.DbModels.DietaryPreference.Vegetarian;
                    var primaryImg = item.Images?.FirstOrDefault(i => i.IsPrimary)?.ImageUrl 
                                     ?? item.Images?.FirstOrDefault()?.ImageUrl 
                                     ?? "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?auto=format&fit=crop&q=80&w=400";
                    var firstPortion = item.Portions?.FirstOrDefault();
                    var categoryIds = string.Join(",", item.Categories?.Select(c => c.CategoryId) ?? new List<int>());

                    <div class="menu-card" 
                         x-show="matchesFilter(@item.Id, '@categoryIds', '@(isVeg ? "veg" : "nonveg")', $el)"
                         data-item-id="@item.Id" 
                         data-item-name="@item.Name"
                         data-diet-pref="@(isVeg ? "veg" : "nonveg")"
                         data-category-ids="@categoryIds"
                         data-search-text="@item.Name.ToLower() @item.Description.ToLower()">
                        
                        <div class="menu-image-container">
                            <img src="@primaryImg" alt="@item.Name" class="menu-img" />
                            <div class="preference-badge @(isVeg ? "pref-veg" : "pref-nonveg")">
                                <span class="badge-dot"></span>
                                <span>@(isVeg ? "Veg" : "Non-Veg")</span>
                            </div>
                        </div>

                        <div class="menu-card-body">
                            <h3 class="item-title">@item.Name</h3>
                            <p class="item-desc">@item.Description</p>
                            
                            <div class="item-interactive">
                                @if (item.Portions != null && item.Portions.Count > 1)
                                {
                                    <div class="portion-select-wrapper">
                                        <label class="portion-label">Select Portion</label>
                                        <select class="portion-select" 
                                                x-init="setPortion(@item.Id, $el.value, parseFloat($el.options[$el.selectedIndex].getAttribute('data-price')))"
                                                x-on:change="setPortion(@item.Id, $el.value, parseFloat($el.options[$el.selectedIndex].getAttribute('data-price')))">
                                            @foreach (var port in item.Portions)
                                            {
                                                <option value="@port.Name" data-price="@port.Price">@port.Name - ₹@port.Price</option>
                                            }
                                        </select>
                                    </div>
                                }
                                else if (firstPortion != null)
                                {
                                    <!-- Hidden select to simplify cart JS logic -->
                                    <select class="portion-select" style="display:none;"
                                            x-init="setPortion(@item.Id, '@firstPortion.Name', @firstPortion.Price)">
                                        <option value="@firstPortion.Name" data-price="@firstPortion.Price">@firstPortion.Name</option>
                                    </select>
                                }

                                <div class="price-display-row">
                                    <span class="price-label">Price</span>
                                    <span class="price-value" x-text="'₹' + getItemPrice(@item.Id, @(firstPortion?.Price ?? 0)).toFixed(2)"></span>
                                </div>
                            </div>

                            <!-- Cart CTA wrapper -->
                            <div>
                                <button class="add-to-cart-btn" 
                                        x-show="getCartItemQty(@item.Id, '@(firstPortion?.Name ?? "Regular")') === 0"
                                        x-on:click="addToCart(@item.Id, $el.closest('.menu-card').getAttribute('data-item-name'), '@(firstPortion?.Name ?? "Regular")', @(firstPortion?.Price ?? 0))">
                                    <i class="bi bi-plus-circle"></i>
                                    <span>Add to Order</span>
                                </button>
                                
                                <div class="qty-controls" 
                                     x-show="getCartItemQty(@item.Id, '@(firstPortion?.Name ?? "Regular")') > 0">
                                    <button class="qty-btn" x-on:click="adjustQty(@item.Id, '@(firstPortion?.Name ?? "Regular")', @(firstPortion?.Price ?? 0), -1)"><i class="bi bi-dash"></i></button>
                                    <span class="qty-number" x-text="getCartItemQty(@item.Id, '@(firstPortion?.Name ?? "Regular")')"></span>
                                    <button class="qty-btn" x-on:click="adjustQty(@item.Id, '@(firstPortion?.Name ?? "Regular")', @(firstPortion?.Price ?? 0), 1)"><i class="bi bi-plus"></i></button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Slide-Out Shopping Cart Panel -->
    <div class="cart-overlay" :class="{ 'active': cartOpen }" x-on:click="cartOpen = false"></div>
    <div class="cart-panel" :class="{ 'active': cartOpen }" id="cart-sidebar">
        <div class="cart-header">
            <h3 style="font-size: 20px; font-weight: 700;"><i class="bi bi-bag-check" style="color: var(--brand-primary); margin-right: 8px;"></i>Your Order</h3>
            <button class="cart-close-btn" x-on:click="cartOpen = false" aria-label="Close Cart">
                <i class="bi bi-x-lg" style="font-size: 20px;"></i>
            </button>
        </div>
        
        <div class="cart-items-list" id="cart-items-container">
            <!-- Empty state -->
            <div class="cart-empty-state" x-show="cart.length === 0" style="display: flex;">
                <i class="bi bi-cart-x"></i>
                <p>Your cart is empty.<br>Add some delicious meals from the menu to get started!</p>
            </div>

            <!-- Cart Items loop -->
            <template x-for="item in cart" :key="item.itemId + '_' + item.portion">
                <div class="cart-item">
                    <div class="cart-item-info">
                        <div class="cart-item-name" x-text="item.name"></div>
                        <div class="cart-item-portion" x-text="item.portion"></div>
                        <div class="cart-item-price" x-text="'₹' + item.price.toFixed(2)"></div>
                    </div>
                    <div class="cart-item-actions">
                        <button class="cart-item-btn" x-on:click="adjustItemQtyFromCart(item.itemId, item.portion, -1)" title="Decrease Quantity">&minus;</button>
                        <span class="cart-item-qty" x-text="item.quantity"></span>
                        <button class="cart-item-btn" x-on:click="adjustItemQtyFromCart(item.itemId, item.portion, 1)" title="Increase Quantity">&plus;</button>
                        <button class="cart-item-btn" x-on:click="removeItemFromCart(item.itemId, item.portion)" style="margin-left: 8px; color: #dc3545; border-color: rgba(220, 53, 69, 0.2);" title="Remove Item"><i class="bi bi-trash"></i></button>
                    </div>
                </div>
            </template>
        </div>
        
        <div class="cart-summary" x-show="cart.length > 0">
            <div class="summary-row">
                <span>Subtotal</span>
                <span x-text="'₹' + subtotal.toFixed(2)"></span>
            </div>
            <div class="summary-row">
                <span>GST (5%)</span>
                <span x-text="'₹' + gst.toFixed(2)"></span>
            </div>
            <div class="summary-row">
                <span>Packaging / Service</span>
                <span x-text="'₹' + packagingFee.toFixed(2)"></span>
            </div>
            <div class="summary-row total">
                <span>Grand Total</span>
                <span x-text="'₹' + grandTotal.toFixed(2)"></span>
            </div>
            
            <!-- Checkout Form -->
            <form class="checkout-form" x-on:submit.prevent="submitLandingOrder">
                <div class="form-group">
                    <label class="form-label" for="cust-name">Customer Name *</label>
                    <input type="text" id="cust-name" class="form-input" placeholder="Enter your full name" x-model="custName" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="cust-phone">Mobile Number *</label>
                    <input type="tel" id="cust-phone" class="form-input" placeholder="10-digit mobile number" pattern="[0-9]{10}" x-model="custPhone" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="cust-order-type">Dining Preference</label>
                    <select id="cust-order-type" class="form-select" x-model="custOrderType">
                        <option value="DineIn">Dine-in (At Restaurant)</option>
                        <option value="Takeaway">Takeaway (Pick up)</option>
                        <option value="Delivery">Home Delivery</option>
                    </select>
                </div>
                <div class="form-group" id="group-table-number" x-show="custOrderType === 'DineIn'">
                    <label class="form-label" for="cust-table">Table Number</label>
                    <input type="text" id="cust-table" class="form-input" placeholder="e.g. Table 4" x-model="custTable">
                </div>
                <div class="form-group" id="group-delivery-address" x-show="custOrderType === 'Delivery'">
                    <label class="form-label" for="cust-address">Delivery Address *</label>
                    <input type="text" id="cust-address" class="form-input" placeholder="Street, Flat/House No, LandMark" x-model="custAddress" :required="custOrderType === 'Delivery'">
                </div>
                
                <button type="submit" class="checkout-submit-btn" :disabled="isSubmitting">
                    <i :class="isSubmitting ? 'bi bi-hourglass-split' : 'bi bi-check2-circle'"></i>
                    <span x-text="isSubmitting ? 'Processing Order...' : 'Confirm & Place Order'"></span>
                </button>
            </form>
        </div>
    </div>

    <!-- Order Success Modal Dialog -->
    <div class="modal-overlay" :class="{ 'active': showSuccessModal }">
        <div class="success-modal">
            <div class="success-icon-wrapper">
                <i class="bi bi-check2"></i>
            </div>
            <h3>Order Confirmed!</h3>
            <p>Your order has been successfully placed and sent to the kitchen. Get ready for a delicious feast!</p>
            
            <div class="order-detail-card">
                <div class="order-detail-row">
                    <span>Order Reference ID:</span>
                    <strong x-text="successOrderRef"></strong>
                </div>
                <div class="order-detail-row">
                    <span>Customer Name:</span>
                    <strong x-text="successCustName"></strong>
                </div>
                <div class="order-detail-row">
                    <span>Grand Total Paid/Owed:</span>
                    <strong style="color: var(--brand-primary)" x-text="successGrandTotal"></strong>
                </div>
            </div>
            
            <button class="btn btn-primary" x-on:click="showSuccessModal = false" style="width: 100%; justify-content: center;">
                Back to Menu &amp; Order Again
            </button>
        </div>
    </div>

    <!-- Footer Area -->
    <footer class="footer-simple" id="footer">
        <div class="container">
            <div class="footer-grid-simple">
                <div class="footer-col">
                    <div class="footer-title">@restaurantName</div>
                    <p style="margin-bottom: 20px; max-width: 320px;">Indulge in premium quality, freshly made culinary creations prepared with love and organic ingredients.</p>
                    <div class="flex" style="gap: 15px; font-size: 18px; color: white;">
                        <a href="#" style="color: inherit;"><i class="bi bi-facebook"></i></a>
                        <a href="#" style="color: inherit;"><i class="bi bi-instagram"></i></a>
                        <a href="#" style="color: inherit;"><i class="bi bi-twitter-x"></i></a>
                    </div>
                </div>
                
                <div class="footer-col">
                    <h5>Our Services</h5>
                    <ul class="footer-links-simple">
                        <li><a href="#">Dine-in</a></li>
                        <li><a href="#">Takeaway Menu</a></li>
                        <li><a href="#">Contactless Delivery</a></li>
                        <li><a href="#">Corporate Catering</a></li>
                    </ul>
                </div>
                
                <div class="footer-col">
                    <h5>Contact Info</h5>
                    <ul class="footer-links-simple">
                        <li style="font-size: 14px; margin-bottom: 10px;"><i class="bi bi-geo-alt" style="margin-right: 8px; color: var(--brand-primary);"></i> @address</li>
                        <li style="font-size: 14px; margin-bottom: 10px;"><i class="bi bi-telephone" style="margin-right: 8px; color: var(--brand-primary);"></i> +91 98765 43210</li>
                        <li style="font-size: 14px; margin-bottom: 10px;"><i class="bi bi-envelope" style="margin-right: 8px; color: var(--brand-primary);"></i> info@@gourmetrestro.com</li>
                    </ul>
                </div>
            </div>
            
            <div class="footer-bottom-simple">
                <p>&copy; 2026 @restaurantName. All rights reserved. Powered by Restro Cloud Management.</p>
                <div class="flex" style="gap: 20px;">
                    <a href="#" style="color: inherit; text-decoration: none;">Privacy Policy</a>
                    <a href="#" style="color: inherit; text-decoration: none;">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripting for cart dynamics, tab filters, and AJAX submissions -->
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('restaurantApp', () => ({
                activeCategory: 'all',
                activeDiet: 'all',
                searchQuery: '',
                cart: [],
                cartOpen: false,
                mobileMenuOpen: false,
                showSuccessModal: false,
                successOrderRef: '',
                successCustName: '',
                successGrandTotal: '₹0.00',
                
                // Form details
                custName: '',
                custPhone: '',
                custOrderType: 'DineIn',
                custTable: '',
                custAddress: '',
                isSubmitting: false,

                // Portions selected for each item: { itemId: { name: 'Regular', price: 150 } }
                selectedPortions: {},

                // Get currently selected portion name for an item
                getSelectedPortionName(itemId, defaultPortionName) {
                    if (!this.selectedPortions[itemId]) {
                        this.selectedPortions[itemId] = { name: defaultPortionName, price: 0 };
                    }
                    return this.selectedPortions[itemId].name;
                },

                // Set selected portion for an item
                setPortion(itemId, name, price) {
                    this.selectedPortions[itemId] = { name, price };
                },

                // Get current price of an item
                getItemPrice(itemId, defaultPrice) {
                    if (this.selectedPortions[itemId] && this.selectedPortions[itemId].price > 0) {
                        return this.selectedPortions[itemId].price;
                    }
                    return defaultPrice;
                },

                // Add to cart
                addToCart(itemId, name, defaultPortion, defaultPrice) {
                    let portion = defaultPortion;
                    let price = defaultPrice;
                    if (this.selectedPortions[itemId]) {
                        portion = this.selectedPortions[itemId].name;
                        price = this.selectedPortions[itemId].price || defaultPrice;
                    } else {
                        this.selectedPortions[itemId] = { name: portion, price: price };
                    }

                    const existingIndex = this.cart.findIndex(item => item.itemId === itemId && item.portion === portion);
                    if (existingIndex > -1) {
                        this.cart[existingIndex].quantity += 1;
                    } else {
                        this.cart.push({
                            itemId: itemId,
                            name: name,
                            portion: portion,
                            price: price,
                            quantity: 1
                        });
                    }
                },

                // Get quantity in cart for the current portion
                getCartItemQty(itemId, defaultPortion) {
                    const portion = this.selectedPortions[itemId] ? this.selectedPortions[itemId].name : defaultPortion;
                    const cartItem = this.cart.find(item => item.itemId === itemId && item.portion === portion);
                    return cartItem ? cartItem.quantity : 0;
                },

                // Adjust quantity from menu card UI buttons
                adjustQty(itemId, defaultPortion, defaultPrice, change) {
                    let portion = defaultPortion;
                    if (this.selectedPortions[itemId]) {
                        portion = this.selectedPortions[itemId].name;
                    }
                    const itemIndex = this.cart.findIndex(item => item.itemId === itemId && item.portion === portion);
                    if (itemIndex > -1) {
                        this.cart[itemIndex].quantity += change;
                        if (this.cart[itemIndex].quantity <= 0) {
                            this.cart.splice(itemIndex, 1);
                        }
                    } else if (change > 0) {
                        this.addToCart(itemId, '', defaultPortion, defaultPrice);
                    }
                },

                // Adjust quantity inside sidebar cart list
                adjustItemQtyFromCart(itemId, portion, change) {
                    const index = this.cart.findIndex(item => item.itemId === itemId && item.portion === portion);
                    if (index > -1) {
                        this.cart[index].quantity += change;
                        if (this.cart[index].quantity <= 0) {
                            this.cart.splice(index, 1);
                        }
                    }
                },

                // Remove item entirely from the cart
                removeItemFromCart(itemId, portion) {
                    const index = this.cart.findIndex(item => item.itemId === itemId && item.portion === portion);
                    if (index > -1) {
                        this.cart.splice(index, 1);
                    }
                },

                // Totals
                get subtotal() {
                    return this.cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
                },

                get gst() {
                    return this.subtotal * 0.05;
                },

                get packagingFee() {
                    if (this.cart.length === 0) return 0;
                    return this.custOrderType === 'Delivery' ? 40 : 20;
                },

                get grandTotal() {
                    if (this.cart.length === 0) return 0;
                    return this.subtotal + this.gst + this.packagingFee;
                },

                get totalQty() {
                    return this.cart.reduce((sum, item) => sum + item.quantity, 0);
                },

                // Visibility matching filters
                matchesFilter(itemId, categoryIdsStr, dietPref, el) {
                    const categoryIds = categoryIdsStr.split(',');
                    const matchesCategory = (this.activeCategory === 'all' || categoryIds.includes(this.activeCategory.toString()));
                    const matchesDiet = (this.activeDiet === 'all' || dietPref === this.activeDiet);
                    
                    const q = this.searchQuery.toLowerCase().trim();
                    const searchText = el ? el.getAttribute('data-search-text') || '' : '';
                    const matchesSearch = (q === '' || searchText.includes(q));

                    return matchesCategory && matchesDiet && matchesSearch;
                },

                // Order submission
                submitLandingOrder() {
                    if (this.isSubmitting) return;
                    this.isSubmitting = true;

                    const orderItems = this.cart.map(item => ({
                        foodItemId: item.itemId,
                        portionName: item.portion,
                        price: item.price,
                        quantity: item.quantity
                    }));

                    const payload = {
                        customerName: this.custName.trim(),
                        mobileNumber: this.custPhone.trim(),
                        orderType: this.custOrderType,
                        tableNumber: this.custOrderType === 'DineIn' ? this.custTable.trim() : null,
                        deliveryAddress: this.custOrderType === 'Delivery' ? this.custAddress.trim() : null,
                        items: orderItems
                    };

                    fetch('/Home/PlaceLandingOrder', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(payload)
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            this.successOrderRef = `#ORD-${data.orderId}`;
                            this.successCustName = this.custName.trim();
                            this.successGrandTotal = `₹${this.grandTotal.toFixed(2)}`;
                            
                            this.showSuccessModal = true;
                            
                            // Clear cart
                            this.cart = [];
                            this.cartOpen = false;
                            
                            // Reset form
                            this.custName = '';
                            this.custPhone = '';
                            this.custOrderType = 'DineIn';
                            this.custTable = '';
                            this.custAddress = '';
                        } else {
                            alert(data.message || "An error occurred while placing the order. Please try again.");
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        alert("Failed to reach server. Please check your internet connection.");
                    })
                    .finally(() => {
                        this.isSubmitting = false;
                    });
                }
            }));
        });
    </script>
</body>
</html>
