@model RestroManagement.DbModels.Order

@{
    ViewData["Title"] = "Order Details";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-link p-0 text-decoration-none text-muted mb-2">
        <i class="bi bi-arrow-left"></i> Back to Orders
    </a>
    <h2 class="fw-bold">Order #@Model.Id</h2>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card p-4 mb-4">
            <h5 class="fw-bold mb-4">Items Ordered</h5>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Portion</th>
                            <th>Qty</th>
                            <th>Price</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items ?? new List<RestroManagement.DbModels.OrderItem>()) {
                        <tr>
                            <td>@item.FoodItem?.Name</td>
                            <td>@(item.Portion?.Name ?? "Regular")</td>
                            <td>@item.Quantity</td>
                            <td>₹@item.Price</td>
                            <td class="text-end fw-bold">₹@(item.Price * item.Quantity)</td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card p-4 mb-4 text-center">
            <h5 class="fw-bold mb-3">Order Status</h5>
            @{
                string statusBadgeClass = "bg-secondary";
                string statusText = Model.Status.ToString();
                switch (Model.Status)
                {
                    case RestroManagement.DbModels.OrderStatus.Pending:
                        statusBadgeClass = "bg-warning-subtle text-warning border border-warning";
                        statusText = "Pending";
                        break;
                    case RestroManagement.DbModels.OrderStatus.Accepted:
                        statusBadgeClass = "bg-info-subtle text-info border border-info";
                        statusText = "Accepted";
                        break;
                    case RestroManagement.DbModels.OrderStatus.Preparing:
                        statusBadgeClass = "bg-primary-subtle text-primary border border-primary";
                        statusText = "Preparing";
                        break;
                    case RestroManagement.DbModels.OrderStatus.Ready:
                        statusBadgeClass = "bg-success-subtle text-success border border-success";
                        statusText = "Ready";
                        break;
                    case RestroManagement.DbModels.OrderStatus.Delivered:
                        statusBadgeClass = "bg-success text-white";
                        statusText = "Delivered";
                        break;
                    case RestroManagement.DbModels.OrderStatus.Cancelled:
                        statusBadgeClass = "bg-danger-subtle text-danger border border-danger";
                        statusText = "Cancelled";
                        break;
                }
            }
            <span class="badge @statusBadgeClass px-4 py-2.5 rounded-pill fw-bold fs-6">
                @statusText
            </span>
        </div>

        <div class="card p-4 mb-4">
            <h5 class="fw-bold mb-4">Customer Info</h5>
            <p class="mb-1 text-muted">Name</p>
            <p class="fw-bold mb-3">@Model.CustomerName</p>
            <p class="mb-1 text-muted">Mobile</p>
            <p class="fw-bold mb-3">@Model.MobileNumber</p>
            <p class="mb-1 text-muted">Order Date</p>
            <p class="fw-bold">@Model.OrderDate.ToString("F")</p>
        </div>

        <div class="card p-4 bg-light">
            <h5 class="fw-bold mb-3">Order Summary</h5>
            <div class="d-flex justify-content-between mb-2">
                <span>Subtotal</span>
                <span>₹@Model.TotalPrice</span>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span>SGST (5%)</span>
                <span>₹@Model.SGST</span>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span>CGST (5%)</span>
                <span>₹@Model.CGST</span>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span>Packaging</span>
                <span>₹@Model.PackagingCharges</span>
            </div>
            <hr>
            <div class="d-flex justify-content-between">
                <h5 class="fw-bold">Total Amount</h5>
                <h5 class="fw-bold text-primary">₹@Model.OrderTotal</h5>
            </div>
        </div>
    </div>
</div>
