@model RestroManagement.DbModels.User.AppUser
@{
    ViewData["Title"] = "User Profile";
    var profilePic = !string.IsNullOrEmpty(Model.ProfilePicture) 
        ? Model.ProfilePicture 
        : "https://cdn-icons-png.flaticon.com/512/3135/3135715.png";
    var userRole = ViewBag.Role as string ?? "Guest";
    var orders = ViewBag.Orders as List<RestroManagement.DbModels.Order> ?? new List<RestroManagement.DbModels.Order>();
}

<div class="container py-4">
    <!-- Success Message Alert -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Sidebar Profile Card -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden text-center h-100">
                <!-- Cover Banner -->
                <div class="profile-cover" style="height: 120px; background: linear-gradient(135deg, #ff6b6b 0%, #fc8019 100%);"></div>
                
                <!-- Profile Image & Basic Info -->
                <div class="card-body position-relative pt-0" style="margin-top: -60px;">
                    <div class="mb-3">
                        <img src="@profilePic" 
                             alt="Profile Picture" 
                             class="rounded-circle border border-4 border-white shadow-sm object-fit-cover" 
                             style="width: 120px; height: 120px; background-color: #fff;" />
                    </div>
                    
                    <h3 class="fw-bold text-dark mb-1">@Model.FName @Model.LName</h3>
                    <p class="text-muted small mb-3">@Model.Email</p>
                    
                    <!-- Role Badge -->
                    <span class="badge bg-soft-orange text-orange px-3 py-2 rounded-pill fw-semibold mb-4">
                        <i class="bi bi-shield-check me-1"></i> @userRole.ToUpper()
                    </span>

                    <!-- Quick Stats -->
                    <div class="row g-2 border-top border-bottom py-3 my-3">
                        <div class="col-6 border-end">
                            <h4 class="fw-bold text-dark mb-0">@orders.Count</h4>
                            <p class="text-muted small mb-0">Total Orders</p>
                        </div>
                        <div class="col-6">
                            <h4 class="fw-bold text-dark mb-0">Active</h4>
                            <p class="text-muted small mb-0">Account Status</p>
                        </div>
                    </div>

                    <!-- Edit Profile Action Button -->
                    <div class="d-grid mt-4">
                        <a asp-area="Guest" asp-controller="Home" asp-action="Profile" class="btn btn-orange btn-lg rounded-3 shadow-sm py-2 fs-6">
                            <i class="bi bi-pencil-square me-2"></i> Edit Profile
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Details & Order History Section -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold text-dark mb-4 border-bottom pb-2">
                        <i class="bi bi-person-lines-fill text-orange me-2"></i> Personal Details
                    </h4>
                    
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label class="text-muted small d-block">First Name</label>
                            <span class="fw-semibold text-dark fs-5">@Model.FName</span>
                        </div>
                        
                        <div class="col-sm-6">
                            <label class="text-muted small d-block">Last Name</label>
                            <span class="fw-semibold text-dark fs-5">@Model.LName</span>
                        </div>

                        <div class="col-sm-6">
                            <label class="text-muted small d-block">Email Address</label>
                            <span class="fw-semibold text-dark fs-5">@Model.Email</span>
                        </div>

                        <div class="col-sm-6">
                            <label class="text-muted small d-block">Phone Number</label>
                            <span class="fw-semibold text-dark fs-5">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Not Specified" : Model.PhoneNumber)</span>
                        </div>

                        <div class="col-12">
                            <label class="text-muted small d-block">Delivery Address</label>
                            <span class="fw-semibold text-dark fs-6">@(string.IsNullOrEmpty(Model.Address) ? "No address added yet. Click Edit Profile to add one." : Model.Address)</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Past Orders Card -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold text-dark mb-4 border-bottom pb-2">
                        <i class="bi bi-clock-history text-orange me-2"></i> Order History
                    </h4>

                    @if (orders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle border-0">
                                <thead class="table-light rounded-3">
                                    <tr>
                                        <th class="border-0">Order ID</th>
                                        <th class="border-0">Date</th>
                                        <th class="border-0">Customer</th>
                                        <th class="border-0">Total</th>
                                        <th class="border-0">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in orders)
                                    {
                                        <tr>
                                            <td class="fw-semibold text-dark">#@order.Id</td>
                                            <td class="text-muted">@order.OrderDate.ToString("MMM dd, yyyy hh:mm tt")</td>
                                            <td class="text-dark">@order.CustomerName</td>
                                            <td class="fw-bold text-dark">₹@order.OrderTotal.ToString("F2")</td>
                                            <td>
                                                @if (order.Status.ToString() == "Delivered" || order.Status.ToString() == "Completed")
                                                {
                                                    <span class="badge bg-soft-success text-success px-2 py-1 rounded-pill">Delivered</span>
                                                }
                                                else if (order.Status.ToString() == "Cancelled")
                                                {
                                                    <span class="badge bg-soft-danger text-danger px-2 py-1 rounded-pill">Cancelled</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-soft-warning text-warning px-2 py-1 rounded-pill">@order.Status</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <div class="mb-3">
                                <i class="bi bi-bag-x text-muted" style="font-size: 3rem;"></i>
                            </div>
                            <h5 class="text-muted">No orders found</h5>
                            <p class="text-muted small">You haven't placed any orders yet. Visit our menu to place your first order!</p>
                            <a asp-controller="Home" asp-action="Menu" class="btn btn-orange rounded-pill px-4">Browse Menu</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Custom Theme Colors for Orange Branding */
    .text-orange {
        color: #fc8019 !important;
    }
    .btn-orange {
        background-color: #fc8019;
        border-color: #fc8019;
        color: #fff;
        transition: all 0.2s ease-in-out;
    }
    .btn-orange:hover {
        background-color: #e56f0e;
        border-color: #e56f0e;
        color: #fff;
        transform: translateY(-2px);
    }
    
    /* Soft color badges */
    .bg-soft-orange {
        background-color: rgba(252, 128, 25, 0.1) !important;
    }
    .bg-soft-success {
        background-color: rgba(25, 135, 84, 0.1) !important;
    }
    .bg-soft-danger {
        background-color: rgba(220, 53, 69, 0.1) !important;
    }
    .bg-soft-warning {
        background-color: rgba(255, 193, 7, 0.1) !important;
    }
    
    /* Table Styling overrides */
    .table > :not(caption) > * > * {
        padding: 1rem 0.75rem;
    }
    .table tbody tr {
        transition: background-color 0.2s ease-in-out;
    }
    .table tbody tr:hover {
        background-color: #fcfcfc;
    }
    
    /* Animation */
    .card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    .card:hover {
        box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.06) !important;
    }
</style>