@model RestroManagement.DbModels.Order

@{
    ViewData["Title"] = "Order Confirmed";
}

<style>
    :root {
        --primary-brand: #E63946;
        --neutral-dark: #1F2937;
        --veg-green: #2EC4B6;
    }

    .success-card {
        border-radius: 24px;
        border: none;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .success-header {
        background: linear-gradient(135deg, #10B981 0%, #059669 100%);
        color: white;
        padding: 40px;
        text-align: center;
    }

    .success-icon {
        font-size: 4.5rem;
        animation: pulse 2s infinite;
    }

    .details-section {
        background-color: #F9FAFB;
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 30px;
    }

    .receipt-table th {
        background-color: #F3F4F6;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
    }

    .receipt-table td {
        padding: 12px;
        font-weight: 500;
    }

    .grand-total-row {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--primary-brand);
    }

    @@keyframes pulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.08); }
        100% { transform: scale(1); }
    }

    .track-order-container {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        padding: 30px;
        margin: 20px;
        border: 1px solid #eef2f5;
    }
    .stepper-wrapper {
        display: flex;
        justify-content: space-between;
        position: relative;
        margin-bottom: 20px;
    }
    .stepper-wrapper::before {
        content: '';
        position: absolute;
        top: 25px;
        left: 10%;
        width: 80%;
        height: 4px;
        background-color: #e9ecef;
        z-index: 1;
    }
    .stepper-progress {
        position: absolute;
        top: 25px;
        left: 10%;
        height: 4px;
        background: linear-gradient(90deg, #10B981, #059669);
        z-index: 1;
        transition: width 0.4s ease;
    }
    .stepper-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        z-index: 2;
        flex: 1;
    }
    .step-counter {
        position: relative;
        width: 54px;
        height: 54px;
        border-radius: 50%;
        background: #f8f9fa;
        border: 3px solid #e9ecef;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 20px;
        color: #6c757d;
        transition: all 0.4s ease;
    }
    .step-name {
        margin-top: 10px;
        font-size: 14px;
        font-weight: 600;
        color: #6c757d;
        text-align: center;
        transition: all 0.4s ease;
    }
    
    /* Completed state */
    .stepper-item.completed .step-counter {
        background-color: #10B981;
        border-color: #10B981;
        color: #ffffff;
        box-shadow: 0 4px 10px rgba(16, 185, 129, 0.2);
    }
    .stepper-item.completed .step-name {
        color: #10B981;
    }

    /* Active state */
    .stepper-item.active .step-counter {
        background-color: #0d6efd;
        border-color: #0d6efd;
        color: #ffffff;
        box-shadow: 0 4px 15px rgba(13, 110, 253, 0.4);
        animation: pulse-step 2s infinite;
    }
    .stepper-item.active .step-name {
        color: #0d6efd;
        font-weight: 700;
    }

    @@keyframes pulse-step {
        0% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.5); }
        70% { box-shadow: 0 0 0 10px rgba(13, 110, 253, 0); }
        100% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0); }
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card success-card">
                <!-- Success Header -->
                <div class="success-header">
                    <div class="success-icon mb-3">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <h2 class="fw-bold mb-1">Order Confirmed!</h2>
                    <p class="mb-0 opacity-90">Thank you for dining with us. Your order has been sent to the kitchen.</p>
                </div>

                <!-- Live Order Tracking -->
                <div class="track-order-container">
                    <h4 class="fw-bold mb-4 text-center text-dark">🍽️ Live Order Tracking</h4>
                    
                    <div id="cancelled-alert" class="alert alert-danger text-center py-3" style="display: none; border-radius: 12px;">
                        <i class="bi bi-x-circle-fill fs-3 d-block mb-2"></i>
                        <span class="fw-bold fs-5 text-danger">This order has been cancelled.</span>
                    </div>

                    <div id="standard-stepper" class="position-relative">
                        <div class="stepper-wrapper">
                            <div id="stepper-progress" class="stepper-progress" style="width: 0%;"></div>
                            
                            <div class="stepper-item">
                                <div class="step-counter"><i class="bi bi-clipboard-check"></i></div>
                                <div class="step-name">Order Placed</div>
                            </div>
                            <div class="stepper-item">
                                <div class="step-counter"><i class="bi bi-check-circle"></i></div>
                                <div class="step-name">Confirmed</div>
                            </div>
                            <div class="stepper-item">
                                <div class="step-counter"><i class="bi bi-egg-fried"></i></div>
                                <div class="step-name">Preparing</div>
                            </div>
                            <div class="stepper-item">
                                <div class="step-counter"><i class="bi bi-bell"></i></div>
                                <div class="step-name">Ready for Pickup</div>
                            </div>
                            <div class="stepper-item">
                                <div class="step-counter"><i class="bi bi-bag-heart"></i></div>
                                <div class="step-name">Delivered</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Receipt details -->
                <div class="card-body p-3 p-sm-5">
                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <span class="text-muted small">ORDER NUMBER</span>
                            <h5 class="fw-bold text-dark">#RESTRO-@Model.Id</h5>
                        </div>
                        <div class="col-sm-6 text-sm-end">
                            <span class="text-muted small">DATE & TIME</span>
                            <h5 class="fw-bold text-dark">@Model.OrderDate.ToString("dd MMM yyyy, hh:mm tt")</h5>
                        </div>
                    </div>

                    <!-- Customer Details -->
                    <div class="details-section">
                        <h5 class="fw-bold mb-3 text-dark">Customer Details</h5>
                        <div class="row g-2">
                            <div class="col-sm-6">
                                <span class="text-muted small d-block">NAME</span>
                                <span class="fw-bold text-dark">@Model.CustomerName</span>
                            </div>
                            <div class="col-sm-6">
                                <span class="text-muted small d-block">MOBILE NUMBER</span>
                                <span class="fw-bold text-dark">@Model.MobileNumber</span>
                            </div>
                        </div>
                    </div>

                    <!-- Items Ordered -->
                    <h5 class="fw-bold mb-3 text-dark">Dishes Prepared</h5>
                    <div class="table-responsive mb-4">
                        <table class="table receipt-table align-middle text-center">
                            <thead>
                                <tr>
                                    <th class="text-start">Item</th>
                                    <th>Portion</th>
                                    <th>Price</th>
                                    <th>Qty</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Items != null)
                                {
                                    foreach (var item in Model.Items)
                                    {
                                        var total = item.Price * item.Quantity;
                                        <tr>
                                            <td class="text-start fw-bold text-dark">@item.FoodItem?.Name</td>
                                            <td>
                                                <span class="badge bg-light text-dark border">
                                                    @(item.Portion?.Name ?? "Regular")
                                                </span>
                                            </td>
                                            <td>₹@item.Price</td>
                                            <td>@item.Quantity</td>
                                            <td class="text-end fw-bold">₹@total</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Charges Breakdown -->
                    <div class="row justify-content-end">
                        <div class="col-md-6">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Subtotal</span>
                                <span class="fw-bold">₹@Model.TotalPrice</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">SGST (5%)</span>
                                <span>₹@Model.SGST.ToString("F2")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">CGST (5%)</span>
                                <span>₹@Model.CGST.ToString("F2")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Packaging Charges</span>
                                <span>₹@Model.PackagingCharges</span>
                            </div>
                            <div class="d-flex justify-content-between pt-3 border-top mt-3 grand-total-row">
                                <span>Grand Total</span>
                                <span>₹@Model.OrderTotal.ToString("F2")</span>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mt-5">
                        <a asp-controller="Home" asp-action="Menu" class="btn btn-danger btn-lg px-5 py-3 fw-bold" style="border-radius: 12px; box-shadow: 0 4px 12px rgba(230, 57, 70, 0.2);">
                            Order More Items
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var orderId = @Model.Id;
            function pollStatus() {
                $.ajax({
                    url: '@Url.Action("GetOrderStatus", "Order", new { area = "Guest" })',
                    type: 'GET',
                    data: { id: orderId },
                    success: function(data) {
                        updateStepper(data.statusValue);
                        if (data.statusValue === 4 || data.statusValue === 5) {
                            clearInterval(pollInterval);
                        }
                    },
                    error: function(err) {
                        console.error("Error polling order status:", err);
                    }
                });
            }

            function updateStepper(statusVal) {
                var stepsCount = 5;
                if (statusVal === 5) { // Cancelled
                    $('#standard-stepper').hide();
                    $('#cancelled-alert').fadeIn();
                    return;
                }
                $('#cancelled-alert').hide();
                $('#standard-stepper').show();

                var progressWidth = (statusVal / (stepsCount - 1)) * 80;
                $('#stepper-progress').css('width', progressWidth + '%');

                $('.stepper-item').each(function(index) {
                    $(this).removeClass('completed active');
                    if (index < statusVal) {
                        $(this).addClass('completed');
                    } else if (index === statusVal) {
                        $(this).addClass('active');
                    }
                });
            }

            pollStatus();
            var pollInterval = setInterval(pollStatus, 5000);
        });
    </script>
}

