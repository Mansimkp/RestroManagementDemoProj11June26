@model eShop.ViewModels.MerchantRegistrationViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Merchant Registration - eShop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 3rem 0;
        }
        .register-card {
            background: white;
            border-radius: 2rem;
            box-shadow: 0 15px 40px rgba(0,0,0,0.1);
            overflow: hidden;
            width: 100%;
            max-width: 850px;
            padding: 3.5rem;
            animation: fadeIn 0.6s ease-out;
        }
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .brand-logo {
            font-size: 3rem;
            font-weight: 800;
            text-align: center;
            margin-bottom: 0.5rem;
            color: #0c831f;
        }
        .brand-logo span {
            color: #ffc107;
        }
        .form-label {
            font-weight: 600;
            color: #444;
            margin-bottom: 0.4rem;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .form-control, .form-select {
            border-radius: 0.75rem;
            padding: 0.75rem 1rem;
            border: 1px solid #e0e0e0;
            transition: all 0.3s;
            font-size: 0.95rem;
            background-color: #fcfcfc;
        }
        .form-control:focus, .form-select:focus {
            border-color: #0c831f;
            box-shadow: 0 0 0 0.2rem rgba(12, 131, 31, 0.08);
            background-color: #fff;
        }
        .btn-primary {
            background-color: #0c831f;
            border: none;
            border-radius: 0.75rem;
            padding: 1rem;
            font-weight: 700;
            font-size: 1.2rem;
            transition: all 0.3s;
            margin-top: 1.5rem;
            letter-spacing: 1px;
        }
        .btn-primary:hover {
            background-color: #096d18;
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(12, 131, 31, 0.3);
        }
        .footer-text {
            text-align: center;
            margin-top: 2rem;
            color: #777;
            font-size: 0.95rem;
        }
        .footer-text a {
            color: #0c831f;
            text-decoration: none;
            font-weight: 600;
        }
        .footer-text a:hover {
            text-decoration: underline;
        }
        .section-header {
            display: flex;
            align-items: center;
            margin: 2rem 0 1.5rem 0;
        }
        .section-header h5 {
            margin: 0;
            color: #0c831f;
            font-weight: 700;
            white-space: nowrap;
            padding-right: 1.5rem;
            text-transform: uppercase;
            font-size: 1rem;
            letter-spacing: 1px;
        }
        .section-header div {
            flex-grow: 1;
            height: 1px;
            background-color: #eee;
        }
        .form-group-icon {
            position: relative;
        }
        .form-group-icon i {
            position: absolute;
            right: 1rem;
            top: 2.3rem;
            color: #ccc;
        }
    </style>
</head>
<body>
    <div class="register-card">
        <div class="brand-logo"><span>e</span>Shop</div>
        <p class="text-center text-muted mb-4">Partner with us and grow your business today</p>

        <form asp-action="RegisterMerchant" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-4 small text-center"></div>

            <div class="section-header">
                <h5>Personal Details</h5>
                <div></div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="FName" class="form-label">First Name</label>
                    <input asp-for="FName" class="form-control" placeholder="Owner's first name" />
                    <span asp-validation-for="FName" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="LName" class="form-label">Last Name</label>
                    <input asp-for="LName" class="form-control" placeholder="Owner's last name" />
                    <span asp-validation-for="LName" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-label">Business Email</label>
                    <input asp-for="Email" class="form-control" placeholder="contact@yourbusiness.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="10-digit contact number" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Password" class="form-label">Create Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Choose a strong password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Re-enter password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>

            <div class="section-header">
                <h5>Business Information</h5>
                <div></div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="StoreName" class="form-label">Store / Company Name</label>
                    <input asp-for="StoreName" class="form-control" placeholder="Enter your business name" />
                    <span asp-validation-for="StoreName" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="BusinessType" class="form-label">Business Type</label>
                    <select asp-for="BusinessType" class="form-select">
                        <option value="">Select Type</option>
                        <option value="Retail">Retail</option>
                        <option value="Wholesale">Wholesale</option>
                        <option value="Manufacturer">Manufacturer</option>
                        <option value="Service Provider">Service Provider</option>
                    </select>
                    <span asp-validation-for="BusinessType" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="BusinessLicense" class="form-label">Tax ID / License No.</label>
                    <input asp-for="BusinessLicense" class="form-control" placeholder="GSTIN / License number" />
                    <span asp-validation-for="BusinessLicense" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Website" class="form-label">Website (Optional)</label>
                    <input asp-for="Website" class="form-control" placeholder="https://www.yourstore.com" />
                    <span asp-validation-for="Website" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="StoreDescription" class="form-label">Brief Description</label>
                <textarea asp-for="StoreDescription" class="form-control" rows="2" placeholder="Tell us about your products or services..."></textarea>
                <span asp-validation-for="StoreDescription" class="text-danger small"></span>
            </div>

            <div class="section-header">
                <h5>Store Address</h5>
                <div></div>
            </div>

            <div class="mb-3">
                <label asp-for="StoreAddress" class="form-label">Street Address</label>
                <input asp-for="StoreAddress" class="form-control" placeholder="House/Shop No, Street, Locality" />
                <span asp-validation-for="StoreAddress" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="City" class="form-label">City</label>
                    <input asp-for="City" class="form-control" placeholder="City" />
                    <span asp-validation-for="City" class="text-danger small"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="State" class="form-label">State</label>
                    <input asp-for="State" class="form-control" placeholder="State" />
                    <span asp-validation-for="State" class="text-danger small"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="ZipCode" class="form-label">Zip Code</label>
                    <input asp-for="ZipCode" class="form-control" placeholder="Pincode" />
                    <span asp-validation-for="ZipCode" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-grid mt-4">
                <button type="submit" class="btn btn-primary">Submit Application</button>
            </div>
        </form>

        <div class="footer-text">
            Already a merchant partner? <a asp-action="Login">Sign In to Dashboard</a>
        </div>
        <div class="footer-text mt-2">
            Just want to shop? <a asp-action="Register">Create Customer Account</a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
