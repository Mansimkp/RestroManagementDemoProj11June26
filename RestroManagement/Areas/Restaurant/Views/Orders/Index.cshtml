@model IEnumerable<RestroManagement.DbModels.Order>

@{
    ViewData["Title"] = "Orders";
}

<h2 class="fw-bold mb-4">Orders Management</h2>
<form asp-action="Index" method="get" class="row g-3 mb-4">

    <div class="col-md-3">
        <label class="form-label">From Date</label>
        <input type="date"
               name="fromDate"
               class="form-control"
               value="@Context.Request.Query["fromDate"]" />
    </div>

    <div class="col-md-3">
        <label class="form-label">To Date</label>
        <input type="date"
               name="toDate"
               class="form-control"
               value="@Context.Request.Query["toDate"]" />
    </div>

    <div class="col-md-3 d-flex align-items-end">
        <button type="submit" class="btn btn-primary me-2">
            <i class="bi bi-search"></i> Filter
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Reset
        </a>
    </div>

</form>
<div class="card p-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Customer</th>
                    <th>Mobile</th>
                    <th>Order Items</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
				@foreach (var item in Model)
				{
					<tr>
						<td class="fw-bold">#@item.Id</td>
						<td class="fw-bold">@item.CustomerName</td>
						<td>@item.MobileNumber</td>
						@if (item.Items == null || item.Items.Count == 0)
						{
							<td> No Items added </td>
						}
						else if (item.Items.Count == 1)
						{
							<td>
								@item.Items.FirstOrDefault().FoodItem.Name
							</td>
						}
						else
						{
							<td>
								@item.Items.FirstOrDefault().FoodItem.Name + @(item.Items.Count() - 1)
							</td>
						}

						<td>@item.OrderDate.ToString("g")</td>
						<td>₹@item.OrderTotal</td>
						<td>
                            <select class="form-select form-select-sm status-select fw-bold" data-order-id="@item.Id" style="width: 150px; border-radius: 8px;">
                                <option value="0" selected="@(item.Status == RestroManagement.DbModels.OrderStatus.Pending ? "selected" : null)">Pending</option>
                                <option value="1" selected="@(item.Status == RestroManagement.DbModels.OrderStatus.Accepted ? "selected" : null)">Accepted</option>
                                <option value="2" selected="@(item.Status == RestroManagement.DbModels.OrderStatus.Preparing ? "selected" : null)">Preparing</option>
                                <option value="3" selected="@(item.Status == RestroManagement.DbModels.OrderStatus.Ready ? "selected" : null)">Ready</option>
                                <option value="4" selected="@(item.Status == RestroManagement.DbModels.OrderStatus.Delivered ? "selected" : null)">Delivered</option>
                                <option value="5" selected="@(item.Status == RestroManagement.DbModels.OrderStatus.Cancelled ? "selected" : null)">Cancelled</option>
                            </select>
						</td>
						<td class="text-end">
							<a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-2">
								<i class="bi bi-eye"></i> View
							</a>
							<form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
								<button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this order?')">
									<i class="bi bi-trash"></i>
								</button>
							</form>
						</td>
					</tr>
				}

				@if (!Model.Any()) {
                    <tr><td colspan="8" class="text-center py-5 text-muted">No orders found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            function applySelectStyle(select) {
                var val = parseInt($(select).val());
                $(select).removeClass('bg-warning-subtle text-warning border-warning bg-info-subtle text-info border-info bg-primary-subtle text-primary border-primary bg-success-subtle text-success border-success bg-danger-subtle text-danger border-danger');
                if (val === 0) {
                    $(select).addClass('bg-warning-subtle text-warning border-warning');
                } else if (val === 1) {
                    $(select).addClass('bg-info-subtle text-info border-info');
                } else if (val === 2) {
                    $(select).addClass('bg-primary-subtle text-primary border-primary');
                } else if (val === 3) {
                    $(select).addClass('bg-success-subtle text-success border-success');
                } else if (val === 4) {
                    $(select).addClass('bg-success-subtle text-success border-success');
                } else if (val === 5) {
                    $(select).addClass('bg-danger-subtle text-danger border-danger');
                }
            }

            $('.status-select').each(function() {
                applySelectStyle(this);
            });

            function showNotification(message, type = 'success') {
                var toast = $('<div class="toast-notification bg-dark text-white p-3 rounded shadow" style="position: fixed; top: 20px; right: 20px; z-index: 9999; display: none; min-width: 250px; border-left: 5px solid #10B981; font-weight: 600;">' + message + '</div>');
                if (type === 'danger') {
                    toast.css('border-left', '5px solid #EF4444');
                } else if (type === 'warning') {
                    toast.css('border-left', '5px solid #F59E0B');
                } else if (type === 'info') {
                    toast.css('border-left', '5px solid #3B82F6');
                }
                $('body').append(toast);
                toast.fadeIn(300).delay(2500).fadeOut(300, function() {
                    $(this).remove();
                });
            }

            $('.status-select').change(function() {
                var selectEl = this;
                var orderId = $(selectEl).data('order-id');
                var newStatus = $(selectEl).val();

                $.ajax({
                    url: '/Restaurant/Orders/UpdateStatus',
                    type: 'POST',
                    data: {
                        id: orderId,
                        status: newStatus
                    },
                    success: function(response) {
                        if (response.success) {
                            applySelectStyle(selectEl);
                            showNotification('Order #' + orderId + ' updated to ' + response.newStatus, 'success');
                        } else {
                            showNotification('Failed to update: ' + response.message, 'danger');
                        }
                    },
                    error: function() {
                        showNotification('An error occurred while updating status.', 'danger');
                    }
                });
            });
        });
    </script>
}

