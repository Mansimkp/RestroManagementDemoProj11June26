@model IEnumerable<RestroManagement.DbModels.Order>

@{
	ViewData["Title"] = "Orders";
}

<h2 class="fw-bold mb-4">Orders Management</h2>

<div class="card p-4">
	<div class="table-responsive">
		<table class="table table-hover align-middle">
			<thead class="table-light">
				<tr>
					<th>ID</th>
					<th>Customer</th>
					<th>Mobile</th>
					<th>OrderItem</th>
					<th>Date</th>
					<th>Total</th>
					<th>Status</th>
					<th class="text-end">Actions</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var item in Model)
				{
					<tr>
						<td class="fw-bold">#@item.Id</td>
						<td class="fw-bold">@item.CustomerName</td>
						<td>@item.MobileNumber</td>
						@if (item.Items == null || item.Items.Count == 0)
						{
							<td> No Items added </td>
						}
						else if (item.Items.Count == 1)
						{
							<td>
								@item.Items.FirstOrDefault().FoodItem.Name  
							</td>
						}
						else
						{
							<td>
								@item.Items.FirstOrDefault().FoodItem.Name + @(item.Items.Count() - 1)
							</td>
						}

						<td>@item.OrderDate.ToString("g")</td>
						<td>₹@item.OrderTotal</td>
						<td>
                            @{
                                string statusBadgeClass = "bg-secondary";
                                string statusText = item.Status.ToString();
                                switch (item.Status)
                                {
                                    case RestroManagement.DbModels.OrderStatus.Pending:
                                        statusBadgeClass = "bg-warning-subtle text-warning border border-warning";
                                        statusText = "Pending";
                                        break;
                                    case RestroManagement.DbModels.OrderStatus.Accepted:
                                        statusBadgeClass = "bg-info-subtle text-info border border-info";
                                        statusText = "Accepted";
                                        break;
                                    case RestroManagement.DbModels.OrderStatus.Preparing:
                                        statusBadgeClass = "bg-primary-subtle text-primary border border-primary";
                                        statusText = "Preparing";
                                        break;
                                    case RestroManagement.DbModels.OrderStatus.Ready:
                                        statusBadgeClass = "bg-success-subtle text-success border border-success";
                                        statusText = "Ready";
                                        break;
                                    case RestroManagement.DbModels.OrderStatus.Delivered:
                                        statusBadgeClass = "bg-success text-white";
                                        statusText = "Delivered";
                                        break;
                                    case RestroManagement.DbModels.OrderStatus.Cancelled:
                                        statusBadgeClass = "bg-danger-subtle text-danger border border-danger";
                                        statusText = "Cancelled";
                                        break;
                                }
                            }
                            <span class="badge @statusBadgeClass px-3 py-2 rounded fw-semibold">
                                @statusText
                            </span>
						</td>
						<td class="text-end">
							<a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-2">
								<i class="bi bi-eye"></i> View
							</a>
							<form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
								<button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this order?')">
									<i class="bi bi-trash"></i>
								</button>
							</form>
						</td>
					</tr>
				}
				@if (!Model.Any())
				{
					<tr><td colspan="8" class="text-center py-5 text-muted">No orders found.</td></tr>
				}
			</tbody>
		</table>
	</div>
</div>
